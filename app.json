{
  "expo": {
    "name": "XYZ Financial Advisor",
    "slug": "advisorai",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "advisorai",
    "primaryColor": "#1D4ED8",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.xyzfinancial.advisorai",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "AdvisorAI does not use the camera.",
        "NSPhotoLibraryUsageDescription": "AdvisorAI does not access your photos.",
        "NSFaceIDUsageDescription": "AdvisorAI does not use Face ID.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "googleSignIn": {
          "reservedClientId": "YOUR_REVERSED_CLIENT_ID"
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.xyzfinancial.advisorai",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-splash-screen",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "extra": {
      "privacyPolicyUrl": "https://www.xyzfinancial.ph/privacy",
      "supportUrl": "https://www.xyzfinancial.ph/support",
      "eas": {
        "projectId": "7edf3601-6438-407b-8a02-d34f6da665c0"
      }
    },
    "owner": "amchrisgarcia"
  }
}
